<?php
$displayItem = isset($item) && $item ? $item : $feature->item();

$media = method_exists($displayItem, 'primaryMedia') ? $displayItem->primaryMedia() : null;
if (!$media) {
    $media = $feature->media();
}

$popupPropsTerms = $popupPropsTerms ?? [];
$showMedia = $showMedia ?? false;
$showProperties = $showProperties ?? false;
$showLinkedFrom = $showLinkedFrom ?? false;
$showExternalLink = $showExternalLink ?? false;
$relatedItems = $relatedItems ?? [];
$allValuesByTerm = (array) $displayItem->values();
?>

<?php if ($showMedia && $media): ?>
    <div class="mapping-sidebar-media">
        <?php echo $this->thumbnail($media, 'medium'); ?>
    </div>
<?php endif; ?>

<?php if ($showProperties) : ?>
    <dl class="mapping-popup-props">
        <?php if (empty($popupPropsTerms)) : ?>
            <h4><?php echo $this->translate('Properties'); ?></h4>
        <?php endif; ?>
        <?php
        $propertyTerms = $popupPropsTerms ?: array_keys($allValuesByTerm);
        ?>
        <?php foreach ($propertyTerms as $term): ?>
            <?php
            $propertyData = $allValuesByTerm[$term] ?? null;

            $propertyValues = $propertyData['values'] ?? [];
            $propertyValues = array_filter($propertyValues, function ($value) {
                return !method_exists($value, 'isPublic') || $value->isPublic();
            });
            if (!$propertyValues) {
                continue;
            }

            $propRep = $propertyData['property'] ?? null;

            $labelText = $term;
            if (!empty($propertyData['alternate_label'])) {
                $labelText = $propertyData['alternate_label'];
            } elseif ($propRep && method_exists($propRep, 'label')) {
                $labelText = $propRep->label();
            }
            ?>
            <dt><?= $this->escapeHtml($labelText); ?></dt>
            <?php foreach ($propertyValues as $v): ?>
                <dd>
                    <?= method_exists($v, 'asHtml') ? $v->asHtml() : $this->escapeHtml((string) $v); ?>
                </dd>
            <?php endforeach; ?>
        <?php endforeach; ?>
    </dl>
<?php endif; ?>

<?php if ($showLinkedFrom): ?>
    <div class="mapping-sidebar-section mapping-sidebar-linked-from">
        <h4><?php echo $this->translate('Linked from'); ?></h4>
        <?php if ($relatedItems): ?>
            <ul>
                <?php foreach ($relatedItems as $relatedItem): ?>
                    <li>
                        <?php echo $relatedItem->link($relatedItem->displayTitle(null, $this->lang()), null, ['target' => '_blank']); ?>
                    </li>
                <?php endforeach; ?>
            </ul>
        <?php else: ?>
            <p><?php echo $this->translate('No linked items found.'); ?></p>
        <?php endif; ?>
    </div>
<?php endif; ?>

<?php if ($showExternalLink): ?>
    <div class="mapping-sidebar-section mapping-sidebar-external-link">
        <h4><?php echo $this->translate('External link'); ?></h4>
        <?php echo $displayItem->link($this->translate('View full item record'), null, ['target' => '_blank']); ?>
    </div>
<?php endif; ?>

<?php if (!$showMedia && !$showProperties && !$showLinkedFrom && !$showExternalLink): ?>
    <p><?php echo $this->translate('No details configured for this tab.'); ?></p>
<?php endif; ?>
